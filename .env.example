# ==================== DISCORD TOKENS ====================
# One or more Discord user tokens, comma-separated
# Get token from Discord DevTools -> Application -> Storage -> localStorage -> token
DISCORD_TOKENS=token1_here,token2_here,token3_here

# ==================== CHANNEL CONFIG ====================
# Channel IDs to send commands to, comma-separated
# Enable Discord Developer Mode -> Right-click channel -> Copy ID
CHANNEL_IDS=123456789012345678,234567890123456789

# ==================== TIMING CONFIG ====================
# Delay between commands in seconds (min = 20, max = 40)
MIN_DELAY=20
MAX_DELAY=40

# ==================== SELLALL CONFIG ====================
# Run 'owo sellall' every N commands, then cooldown in seconds
SELLALL_INTERVAL=100
SELLALL_COOLDOWN=600

# ==================== GEM CONFIG ====================
# Enable automatic gem equipping (true/false)
GEM_ENABLED=true
# Gem IDs to equip (comma-separated)
# Hunting: 51=C,52=U,53=R,54=E,55=M,56=L,57=F
# Empower: 65=C,66=U,67=R,68=E,69=M,70=L,71=F
# Lucky:   72=C,73=U,74=R,75=E,76=M,77=L,78=F
GEM_IDS=51,52,53,56

# ==================== INVENTORY CONFIG ====================
# Check and use inventory items every N command cycles (0 = disabled)
INVENTORY_CHECK_INTERVAL=25
# Auto-use lootboxes (ID:50) and weapon crates (ID:100)
USE_LOOTBOXES=true
USE_WEAPON_CRATES=true

# ==================== DAILY CLAIM ====================
# Auto-claim owo daily rewards (true/false)
AUTO_CLAIM=true

# ==================== VERIFICATION CONFIG ====================
# Play sound alert when human verification detected
VERIFY_SOUND=true

# ==================== CAPTCHA SERVICE ====================
# Service: manual, capmonster, or 2captcha
CAPTCHA_SERVICE=manual
# API keys (only needed if not using manual)
CAPMONSTER_API_KEY=
TWOCAPTCHA_API_KEY=

# ==================== PER-TOKEN GEM OVERRIDES ====================
# Optional: override gems for specific tokens
# Format: TOKEN_GEMS_tokenprefix=id1,id2,id3
# Example: TOKEN_GEMS_MTIzNDU=56,70,77
# Leave empty to use GEM_IDS for all tokens
TOKEN_GEMS_OVERRIDES=

# ==================== RAILWAY / DEPLOY CONFIG ====================
# Railway system vars (set automatically, don't modify)
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=