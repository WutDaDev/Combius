# ==================== ⚡ COMBIBUS CONFIGURATION ⚡ ====================
# All settings via environment variables — zero secrets in code

# ─── DISCORD CREDENTIALS ───
DISCORD_TOKENS=token1_here,token2_here,token3_here
CHANNEL_IDS=123456789012345678,234567890123456789

# ─── TIMING (Human-like behavior) ───
MIN_DELAY=20
MAX_DELAY=40
DELAY_JITTER=0.3
DELAY_SPIKE_CHANCE=0.05
DELAY_SPIKE_MAX=120

# ─── SELLALL ───
SELLALL_INTERVAL=100
SELLALL_VARIANCE=15
SELLALL_COOLDOWN=600

# ─── GEMS ───
GEM_ENABLED=true
GEM_IDS=51,52,53,56
AUTO_SCAN_GEMS=true
MIN_GEM_TIER=3

# ─── INVENTORY (Auto open everything) ───
INVENTORY_CHECK_INTERVAL=20
AUTO_OPEN_LOOTBOXES=true
AUTO_OPEN_FABLED=true
AUTO_OPEN_CRATES=true

# ─── DAILY ───
AUTO_CLAIM=true
CLAIM_INTERVAL_HOURS=8

# ─── SAFETY ───
VERIFY_SOUND=true
AUTO_BROWSER=true
MAX_COMMANDS_PER_HOUR=120
ANTI_PATTERN_ROTATION=true
MAX_CONSECUTIVE_SAME_CHANNEL=3

# ─── CAPTCHA ───
CAPTCHA_SERVICE=manual
CAPMONSTER_API_KEY=
TWOCAPTCHA_API_KEY=

# ─── UI ───
THEME=dark
SHOW_STATS=true
STATS_INTERVAL=50

# ─── PER-TOKEN GEM OVERRIDES ───
# TOKEN_GEMS_<token_prefix>=id1,id2,id3
# Example: TOKEN_GEMS_MTIzNDU=56,70,77